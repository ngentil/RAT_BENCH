# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # for wiki import scripts only — never expose to frontend

# Admin
VITE_ADMIN_EMAIL=your-admin@email.com

# Observability (optional — leave blank to disable)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Billing (company per-seat subscriptions — leave blank if billing isn't set up yet)
# Publishable key only — safe to expose client-side. The secret key, webhook
# secret, and PRICE_SEAT price ID are Supabase edge function secrets instead
# (never client env vars) — see docs/STRIPE_SETUP.md.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...

